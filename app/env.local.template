# ═══════════════════════════════════════════════════════════
# SNAPLIST — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local in your project ROOT (not /app)
# Never commit .env.local to git

# ── AI (Required for scan/detect/listing generation) ──────
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google Custom Search for price verification
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── Supabase (Required for auth, database, storage) ───────
# Find these in: Supabase Dashboard → Settings → API

# Your project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (server-side only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
